{
  "datasets": [
    {
      "name": "72431d7f",
      "displayName": "Location Data",
      "queryLines": [
        "select latitude, longitude,`GHG emissions mtons CO2e` as Emissions\r\n",
        "from emissions.default.emissions_data"
      ]
    },
    {
      "name": "339100d4",
      "displayName": "Untitled dataset",
      "queryLines": [
        ""
      ]
    },
    {
      "name": "38db030b",
      "displayName": "Untitled dataset 1",
      "queryLines": [
        ""
      ]
    },
    {
      "name": "d5200e3d",
      "displayName": "Emissions per person",
      "queryLines": [
        "select\r\n",
        "  county_state_name,\r\n",
        " population,\r\n",
        "  cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) / cast(population as double) as emissions_per_person\r\n",
        "from emissions_data\r\n",
        "order by emissions_per_person desc\r\n"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "4cc49909",
      "displayName": "Total Emissions Per State",
      "queryLines": [
        "select\r\n",
        "  state_abbr,\r\n",
        "  sum(cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) )\r\n",
        "  as Total_Emmissons    \r\n",
        "from emissions_data\r\n",
        "group by state_abbr\r\n",
        "order by Total_Emmissons desc\r\n",
        "limit 10"
      ]
    },
    {
      "name": "99a5b4e8",
      "displayName": "Conty Shaming",
      "queryLines": [
        "select\r\n",
        "  county_state_name,\r\n",
        " population,\r\n",
        "  cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) as Total_Emissions\r\n",
        "from emissions_data\r\n",
        "order by total_emissions desc\r\n",
        "limit 10"
      ]
    }
  ],
